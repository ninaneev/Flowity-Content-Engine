# ══════════════════════════════════════════════════════════════════
#  Flowity Content Engine — Variáveis de Ambiente
#  PASSO A PASSO:
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha os valores abaixo
#  3. NUNCA comite o arquivo .env (ele já está no .gitignore)
# ══════════════════════════════════════════════════════════════════

# ── BANCO DE DADOS ────────────────────────────────────────────────
# Opção A — Supabase (recomendado para produção):
# Veja docs/supabase-setup.md para obter essa URL
#DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./flowity.db

# Opção B — SQLite local (mais simples para desenvolvimento):
# DATABASE_URL=sqlite:///./flowity.db

# ── AUTENTICAÇÃO JWT ─────────────────────────────────────────────
# Gere uma string aleatória de 64 chars:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-isso-por-uma-string-aleatoria-de-64-chars

# Admin da plataforma (único usuário)
ADMIN_USERNAME=admin

# Hash bcrypt da senha do admin.
# Para gerar: python -c "from passlib.context import CryptContext; c=CryptContext(schemes=['bcrypt']); print(c.hash('sua-senha'))"
ADMIN_PASSWORD_HASH=$2b$12$4d1YE2MbvfNmeHjJkHmjZuhtme5ekO7KYUgfxI5F0PtT07PriLWkK

# ── OLLAMA (IA LOCAL) ────────────────────────────────────────────
# URL interna do Docker (não mude se estiver usando docker compose)
OLLAMA_BASE_URL=http://ollama:11434
# Modelo a usar (baixe com: docker exec -it flowity-ollama ollama pull llama3.1:8b)
OLLAMA_MODEL=llama3.1:8b

# ── N8N (AUTOMAÇÃO) ──────────────────────────────────────────────
# Secret compartilhado entre n8n e backend (coloque qualquer string aleatória)
N8N_WEBHOOK_SECRET=troque-isso-por-uma-string-secreta
N8N_USER=admin
N8N_PASSWORD=flowity123

# ── FRONTEND ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
